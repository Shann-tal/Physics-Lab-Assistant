"""
大物实验数据处理助手 - 程序入口
Physics Lab Data Assistant - Entry Point
"""

import sys
import tkinter as tk
from gui.main_window import MainWindow

def main():
    """程序主函数"""
    # 创建根窗口
    root = tk.Tk()
    
    # 设置窗口标题和大小
    root.title("大物实验数据处理助手 v1.0")
    root.geometry("900x600")
    
    # 创建主界面
    app = MainWindow(root)
    
    # 运行程序
    root.mainloop()

if __name__ == "__main__":
    main()
